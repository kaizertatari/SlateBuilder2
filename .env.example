# Configuration for the LLM router (multi-provider, per-request rotation)
# LLM_PROVIDERS       - comma-separated provider order (default: "groq,gemini"). Set
#                       to "groq" or "gemini" alone to disable routing.
#
# Groq provider
# GROQ_API_KEY        - server only — required if "groq" is in LLM_PROVIDERS
# GROQ_PRIMARY_MODEL  - server only — primary Groq model (default: "llama-3.3-70b-versatile")
# GROQ_FALLBACK_MODEL - server only — fallback Groq model (default: "openai/gpt-oss-120b")
# GROQ_PRIMARY_DELAYS - server only — comma-separated retry delays in ms (default: "0,500,1500")
# GROQ_FALLBACK_DELAY - server only — delay before fallback model in ms (default: "500")
#
# Gemini provider
# GOOGLE_API_KEY        - server only — required if "gemini" is in LLM_PROVIDERS
# GEMINI_PRIMARY_MODEL  - server only — primary Gemini model (default: "gemini-2.5-flash")
# GEMINI_FALLBACK_MODEL - server only — fallback Gemini model (default: "gemini-2.5-flash-lite")
#
# Stats fallback
# BALLDONTLIE_API_KEY - server only — balldontlie.io fallback for stats.nba.com

# Server Port
# PORT - port to listen on for HTTP requests (default: 3000)

# Node Environment
# NODE_ENV - environment (development, production, test) (default: development)

# Rate Limiting
# RATE_LIMIT_WINDOW_MS - window size for rate limiting in milliseconds (default: 60000)
# RATE_LIMIT_MAX_REQUESTS - max requests per window (default: 20)

# Cache TTL (in milliseconds)
# CACHE_TTL_MS - default TTL for cache entries (default: 3600000) # 1 hour
# CACHE_STALE_TTL_MS - default stale TTL for cache entries (default: 7200000) # 2 hours

# ESPN Data
# ESPN_SCOREBOARD_TTL_MS - TTL for ESPN scoreboard data (default: 300000) # 5 minutes
# ESPN_INJURIES_TTL_MS - TTL for ESPN injuries data (default: 3600000) # 1 hour

# Ball Don't Live
# BALldontlie_PLAYER_SEARCH_TTL_MS - TTL for player search (default: 86400000) # 24 hours
# BALldontlie_TEAM_SEARCH_TTL_MS - TTL for team search (default: 86400000) # 24 hours

# Team Defense
# TEAM_DEFENSE_CACHE_FRESH_MS - fresh TTL for team defense data (default: 21600000) # 6 hours
# TEAM_DEFENSE_CACHE_STALE_MS - stale TTL for team defense data (default: 86400000) # 24 hours

# Matchup Defender
# MATCHUP_DEFENDER_CACHE_FRESH_MS - fresh TTL for matchup defender data (default: 21600000) # 6 hours
# MATCHUP_DEFENDER_CACHE_STALE_MS - stale TTL for matchup defender data (default: 86400000) # 24 hours

# Ground Truth
# GROUND_TRUTH_CACHE_FRESH_MS - fresh TTL for ground truth data (default: 300000) # 5 minutes
# GROUND_TRUTH_CACHE_STALE_MS - stale TTL for ground truth data (default: 600000) # 10 minutes

# Request Context
# REQUEST_CONTEXT_LOG_PREFIX - prefix for log messages (default: '[prizeprops] ')