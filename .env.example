# Required. Server-side only — never prefixed VITE_*.
GOOGLE_API_KEY=

# Required. balldontlie.io fallback for stats.nba.com (Vercel egress IPs are
# frequently 403'd by stats.nba.com). Header value is the raw key, no Bearer.
BALLDONTLIE_API_KEY=

# Configuration for rate limiting (requests per window)
# Window size in milliseconds
RATE_LIMIT_WINDOW_MS=60000
# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=10

# Configuration for Gemini AI model
# Primary model to use
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
# Fallback model if primary fails
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
# Delays between retry attempts for primary model (in milliseconds)
# Format: comma-separated values (e.g., "0,500,1500" for 0ms, 500ms, 1500ms)
GEMINI_PRIMARY_DELAYS=0,500,1500
# Delay before trying fallback model (in milliseconds)
GEMINI_FALLBACK_DELAY=500
